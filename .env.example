# Supabase — copiá este archivo a .env y completá con tus credenciales
# (Project Settings -> API en el panel de Supabase)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# WhatsApp del salón (formato internacional sin + ni espacios). Ej: 54911XXXXXXXX
VITE_WHATSAPP_PHONE=5491100000000

# Puente de login con el CRM viejo (neifertcrm.com) — SOLO servidor, sin
# prefijo VITE_ para que Vite NUNCA la incluya en el bundle del navegador.
# Se obtiene en Supabase: Project Settings -> API -> service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Cuenta del CRM viejo (neifertcrm.com) usada por el servidor para sincronizar
# vehículos en segundo plano, sin depender de que haya un admin logueado.
# Recomendado: pedir una cuenta dedicada a "sincronización" en vez de
# reutilizar la de una persona (así no se rompe si esa persona cambia su clave).
CRM_SYNC_USER=usuario_del_crm
CRM_SYNC_PASS=contraseña_del_crm

# Cloudflare R2 (storage de fotos/video — 10GB gratis, egress gratis para
# siempre; requiere tarjeta para habilitarlo pero no cobra dentro del free
# tier) — SOLO servidor, nunca en el navegador. Pasos:
#  1) Dashboard de Cloudflare -> R2 Object Storage -> habilitar (pide tarjeta).
#  2) Create bucket (ej: neifert-media).
#  3) Bucket -> Settings -> Public access -> Allow Access (R2.dev subdomain,
#     o un dominio propio si ya tenés uno en Cloudflare).
#  4) R2 -> Manage API Tokens -> Create API Token -> Object Read & Write,
#     restringido a ese bucket. Copiá Access Key ID + Secret Access Key ahí
#     mismo (el secret no se vuelve a mostrar).
#  5) El "endpoint" S3 es https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#     (el Account ID se ve en la URL del dashboard o en la pantalla de R2).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
